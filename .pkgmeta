package-as: ApplicantScout

manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown

ignore:
  - .github
  - .gitignore
  - README.md
  - .pkgmeta
  - scripts
  - docs
  - dist
  - tests
  - AGENTS.md
  - AUDIT.md
  - PLAN.md
  - NOTES.md
  - TODO.md
  - CLAUDE.md
  - "*.private.md"
  - "*.private/"
